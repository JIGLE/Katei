# Katei — environment configuration
# Copy to `.env` and adjust before running `docker compose up`.

# --- PostgreSQL ---
POSTGRES_USER=katei
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=katei

# Connection string consumed by the app (node-postgres).
# Host "postgres" matches the compose service name.
DATABASE_URL=postgresql://katei:change_me_in_production@postgres:5432/katei

# --- App ---
# Host port the application (SPA + API) is published on.
# The container always listens on 3000 internally.
APP_PORT=8080

# Katei — environment configuration
# Copy to `.env` and adjust before running `docker compose up`.

# --- PostgreSQL ---
POSTGRES_USER=katei
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=katei

# --- Backend ---
# Port the Fastify API listens on (inside the container and exposed to host).
BACKEND_PORT=3000

# Connection string consumed by the backend (node-postgres).
# Host "postgres" matches the compose service name.
DATABASE_URL=postgresql://katei:change_me_in_production@postgres:5432/katei

# --- Frontend ---
# Host port the nginx-served SPA is published on.
FRONTEND_PORT=8080

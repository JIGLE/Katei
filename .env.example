# Katei — environment configuration
# Copy to `.env` and adjust before running `docker compose up`.

# Database password (used by both postgres init and the app connection string).
POSTGRES_PASSWORD=change_me_in_production

# Host port the app is published on (container always listens on 3000).
APP_PORT=8080

# Optional: bind-mount a host path for postgres data instead of a named volume.
# Uncomment and set to use a TrueNAS dataset path, e.g.:
# PGDATA_PATH=/mnt/HDD/app-data/databases/katei

# Optional settings overrides. When set, these are written into the app's
# settings table on every boot, so they survive a wiped settings table or a
# fresh volume. Leave unset to manage them in the UI (and auto-generate the
# session secret).
#
# Recommended: set a stable JWT_SECRET so logins survive redeploys / DB resets.
# JWT_SECRET=generate_a_long_random_string
# NTFY_URL=https://ntfy.sh/your-secret-topic
# LEAD_DAYS=3

# Optional: daily database backups (pg_dump) inside the data volume.
# BACKUP_DIR=/var/lib/postgresql/data/katei_backups
# BACKUP_RETENTION=7

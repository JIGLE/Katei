# Katei — environment configuration
# Copy to `.env` and adjust before running `docker compose up`.

# Database password (used by both postgres init and the app connection string).
POSTGRES_PASSWORD=change_me_in_production

# Host port the app is published on (container always listens on 3000).
APP_PORT=8080

# Optional: bind-mount a host path for postgres data instead of a named volume.
# Uncomment and set to use a TrueNAS dataset path, e.g.:
# PGDATA_PATH=/mnt/HDD/app-data/databases/katei
